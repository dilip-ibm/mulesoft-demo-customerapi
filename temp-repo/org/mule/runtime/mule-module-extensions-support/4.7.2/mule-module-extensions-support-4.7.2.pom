<?xml version="1.0" encoding="utf-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <parent>
    <artifactId>mule-modules</artifactId>
    <groupId>org.mule.runtime</groupId>
    <version>4.7.2</version>
  </parent>
  <modelVersion>4.0.0</modelVersion>
  <artifactId>mule-module-extensions-support</artifactId>
  <name>Mule Extensions Support</name>
  <description>Default implementation of the Mule Extension API.</description>
  <build>
    <resources>
      <resource>
        <filtering>true</filtering>
        <directory>${basedir}/src/main/resources</directory>
      </resource>
    </resources>
    <testResources>
      <testResource>
        <filtering>true</filtering>
        <directory>${basedir}/src/test/resources</directory>
      </testResource>
    </testResources>
    <plugins>
      <plugin>
        <artifactId>maven-jar-plugin</artifactId>
        <executions>
          <execution>
            <id>default-test-jar</id>
            <goals>
              <goal>test-jar</goal>
            </goals>
            <configuration>
              <includes>
                <include>*</include>
                <include>org/mule/runtime/module/extension/internal/resources/test/**</include>
                <include>org/mule/runtime/module/extension/internal/loader/parser/java/test/**</include>
                <include>org/mule/runtime/module/extension/internal/util/test/**</include>
                <include>org/mule/test/**</include>
              </includes>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <artifactSet>
                <includes>
                  <includes>org.springframework:spring-core</includes>
                </includes>
              </artifactSet>
              <relocations>
                <relocation>
                  <pattern>org.springframework</pattern>
                  <shadedPattern>org.mule.springframework</shadedPattern>
                </relocation>
              </relocations>
              <filters>
                <filter>
                  <artifact>org.springframework:spring-core</artifact>
                  <excludes>
                    <exclude>META-INF/**</exclude>
                  </excludes>
                </filter>
              </filters>
              <shadeTestJar>true</shadeTestJar>
              <minimizeJar>true</minimizeJar>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <dependencies>
